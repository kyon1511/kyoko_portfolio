// back/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        Int     @id @default(autoincrement())
  name      String
  bio       String
  imageUrl  String
  createdAt DateTime @default(now())
}

